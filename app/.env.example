# --- LLM (required) ------------------------------------------------------
# DeepSeek API key used by the generation backend (api/generate.js).
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# Optional: override the DeepSeek model (default: deepseek-v4-pro).
# DEEPSEEK_MODEL=deepseek-v4-pro

# --- Database ------------------------------------------------------------
# Postgres connection string (Vercel Postgres / Neon / Supabase).
# Leave EMPTY for local dev — the app falls back to embedded PGlite persisted
# to app/.data/pg (survives restarts, zero setup).
DATABASE_URL=

# --- Build-order emails (optional) ---------------------------------------
# Gmail SMTP for the "Build" order form. Requires a Gmail APP PASSWORD
# (not your normal password): https://myaccount.google.com/apppasswords
GMAIL_USER=akhandelwal3021@gmail.com
GMAIL_APP_PASSWORD=
# Where order emails are delivered (defaults to GMAIL_USER).
ORDER_RECIPIENT=akhandelwal3021@gmail.com
